---
import about from '/aboutMe.jpg';
---

<div id='about' class='my-20'>
  <h1 class='text-center text-3xl text-gray-700 dark:text-gray-200 font-bold mb-8'>About me</h1>
  <div
    id='grid'
    class='bg-white dark:bg-[#111] rounded-xl grid grid-flow-row items-center justify-center justify-items-center gap-6 lg:grid-cols-2 m-6 min-[300px]:m-10 sm:m-16 p-3 md:p-5 transition-colors duration-300'
  >
    <div class='flex justify-center w-full'>
      <img class='w-[75%] sm:w-[65%] md:w-[55%] lg:w-[70%] rounded-xl' src={about} alt='about image' />
    </div>
    <div class='text-gray-500 dark:text-gray-400 p-1 min-[250px]:p-2 min-[450px]:p-4'>
      <h3
        class='text-base min-[500px]:text-xl min-[850px]::text-2xl font-bold text-gray-700 dark:text-gray-200 lg:my-2'
      >
        Hi, I'm Aakash Dwivedy,
      </h3>
      <h3
        class='text-sm min-[500px]:text-base min-[850px]:text-lg font-semibold my-1 lg:my-2'
      >
        Senior Android Developer based in Bangalore, India.
      </h3>
      <div class='md:space-y-2'>
        <h3 class='text-xs min-[500px]:text-sm min-[850px]:text-base my-1'>
          With over 2.5+ years of experience, I specialize in building scalable,
          high-performance mobile applications using Kotlin and Jetpack Compose.
        </h3>
        <h3 class='text-xs min-[500px]:text-sm min-[850px]:text-base my-1'>
          I'm currently diving deep into AI/ML and love engineering solutions
          that bridge the gap between complex tech like on-device RAG
          pipelines and seamless user experiences.
        </h3>
        <h3
          class='text-xs min-[500px]:text-sm min-[850px]:text-base my-1 lg:mb-2'
        >
          I'm always looking to collaborate on innovative mobile and AI applications.
        </h3>
      </div>
    </div>
  </div>
</div>
