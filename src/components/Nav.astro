---
const navLinks = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/#about' },
  { name: 'Skills', href: '/#skills' },
  { name: 'Projects', href: '/#projects' },
  { name: 'Experience', href: '/#experience' },
  { name: 'Contact', href: '/#contact' },
];
---

<nav class='relative z-50 w-full py-6 md:py-8'>
  <div class='max-w-7xl mx-auto px-6 lg:px-8 flex items-center justify-between'>

    <a
      href='/'
      class='text-2xl font-bold tracking-tight text-gray-900 dark:text-white hover:opacity-80 transition-opacity'
    >
      Aakash
    </a>

    <div class='flex items-center gap-6 md:gap-8'>

      {/* Desktop Nav */}
      <div class='hidden lg:flex items-center gap-8'>
        {navLinks.map((link) => (
          <a
            href={link.href}
            class='text-base font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors duration-200'
          >
            {link.name}
          </a>
        ))}
      </div>

      {/* Theme Toggle Button */}
      <button
        id='theme-toggle'
        class='p-2 rounded-full text-gray-600 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-neutral-800 transition-colors'
        aria-label='Toggle Dark Mode'
      >
        <svg id='theme-icon-light' xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5 hidden">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
        </svg>
        <svg id='theme-icon-dark' xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5 hidden">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
        </svg>
      </button>

      {/* Hamburger Menu Toggle */}
      <div
        id='hamburger-toggle'
        class='lg:hidden cursor-pointer space-y-1.5 z-50 p-2 -mr-2 relative'
      >
        <span class='line-1 block h-0.5 w-6 bg-gray-900 dark:bg-white transition-all duration-300 transform origin-center'></span>
        <span class='line-2 block h-0.5 w-6 bg-gray-900 dark:bg-white transition-all duration-300 transform origin-center'></span>
        <span class='line-3 block h-0.5 w-4 bg-gray-900 dark:bg-white ml-auto transition-all duration-300 transform origin-center'></span>
      </div>
    </div>
  </div>

  {/* Hamburger Menu Overlay */}
  <div id='mobile-menu' class='fixed inset-0 z-40 flex items-center justify-center bg-white dark:bg-[#111] transition-all duration-500 opacity-0 pointer-events-none translate-y-4'>
    <div class='flex flex-col items-center gap-8'>
      {navLinks.map((link) => (
        <a
          href={link.href}
          class='mobile-link text-2xl sm:text-3xl font-bold tracking-tight text-gray-900 dark:text-white hover:text-gray-500 transition-colors'
        >
          {link.name}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  // Setup theme on load
  const isDark = document.documentElement.classList.contains('dark');
  const iconLight = document.getElementById('theme-icon-light');
  const iconDark = document.getElementById('theme-icon-dark');
  
  const updateIcons = (dark) => {
    if (dark) {
      iconDark?.classList.remove('hidden');
      iconLight?.classList.add('hidden');
    } else {
      iconLight?.classList.remove('hidden');
      iconDark?.classList.add('hidden');
    }
  };
  updateIcons(isDark);

  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const isDarkNow = document.documentElement.classList.toggle('dark');
    if (isDarkNow) {
      localStorage.setItem('theme', 'dark');
    } else {
      localStorage.setItem('theme', 'light');
    }
    updateIcons(isDarkNow);
  });

  // Mobile Menu Toggle
  const toggleBtn = document.getElementById('hamburger-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const line1 = toggleBtn?.querySelector('.line-1');
  const line2 = toggleBtn?.querySelector('.line-2');
  const line3 = toggleBtn?.querySelector('.line-3');
  const mobileLinks = document.querySelectorAll('.mobile-link');
  
  let menuOpen = false;

  const toggleMenu = () => {
    menuOpen = !menuOpen;
    
    if (menuOpen) {
      mobileMenu?.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-4');
      mobileMenu?.classList.add('opacity-100', 'translate-y-0');
      
      line1?.classList.add('rotate-45', 'translate-y-2');
      line2?.classList.add('opacity-0', 'w-0');
      line3?.classList.remove('w-4');
      line3?.classList.add('w-6', '-rotate-45', '-translate-y-2');
      
      document.body.style.overflow = 'hidden';
    } else {
      mobileMenu?.classList.add('opacity-0', 'pointer-events-none', 'translate-y-4');
      mobileMenu?.classList.remove('opacity-100', 'translate-y-0');
      
      line1?.classList.remove('rotate-45', 'translate-y-2');
      line2?.classList.remove('opacity-0', 'w-0');
      line3?.classList.remove('w-6', '-rotate-45', '-translate-y-2');
      line3?.classList.add('w-4');
      
      document.body.style.overflow = '';
    }
  };

  toggleBtn?.addEventListener('click', toggleMenu);
  
  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      if (menuOpen) toggleMenu();
    });
  });
</script>
