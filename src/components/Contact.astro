---
import contactImg from '/contact.png';
---

<section id='contact' class='py-8 md:py-12 max-w-7xl mx-auto px-6 lg:px-8'>
  
  <h2 class='text-center text-3xl font-bold text-gray-900 dark:text-white mb-10 tracking-tight'>
    Get in touch!
  </h2>

  <div class='grid grid-cols-1 lg:grid-cols-12 items-center gap-10 lg:gap-16'>
    
    <div class='lg:col-span-5 flex justify-center w-full order-1 mb-8 lg:mb-0 group'>
      <img
        class='w-[70%] sm:w-[60%] md:w-[50%] lg:w-[90%] max-w-sm h-auto transition-transform duration-500 ease-in-out group-hover:scale-[1.02]'
        src={contactImg}
        alt='contact image'
      />
    </div>

    <form
      id='contact-form'
      class='lg:col-span-7 flex flex-col bg-gray-50 dark:bg-[#111] rounded-2xl border border-gray-100 dark:border-neutral-800 shadow-lg shadow-gray-200/40 dark:shadow-none p-6 sm:p-8 md:p-10 transition-all duration-300 w-full order-2'
    >
      <label class='text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5'>Name</label>
      <input
        type='text'
        name='from_name'
        required
        class='mb-5 rounded-xl bg-white dark:bg-neutral-800 border border-gray-200 dark:border-neutral-700 px-4 py-3 text-gray-900 dark:text-white focus:outline-none focus:border-gray-900 dark:focus:border-white focus:ring-1 focus:ring-gray-900 dark:focus:ring-white transition-all duration-200 shadow-sm'
      />
      
      <label class='text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5'>Email</label>
      <input
        type='email'
        name='email_id'
        required
        class='mb-5 rounded-xl bg-white dark:bg-neutral-800 border border-gray-200 dark:border-neutral-700 px-4 py-3 text-gray-900 dark:text-white focus:outline-none focus:border-gray-900 dark:focus:border-white focus:ring-1 focus:ring-gray-900 dark:focus:ring-white transition-all duration-200 shadow-sm'
      />
      
      <label class='text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5'>Message</label>
      <textarea
        name='message'
        required
        rows="4"
        class='mb-6 rounded-xl bg-white dark:bg-neutral-800 border border-gray-200 dark:border-neutral-700 px-4 py-3 text-gray-900 dark:text-white focus:outline-none focus:border-gray-900 dark:focus:border-white focus:ring-1 focus:ring-gray-900 dark:focus:ring-white transition-all duration-200 resize-y shadow-sm'
      ></textarea>
      
      <input
        class='cursor-pointer w-full sm:w-auto self-start px-8 py-3 bg-gray-900 text-white dark:bg-white dark:text-gray-900 rounded-full font-medium hover:bg-gray-800 dark:hover:bg-gray-200 transition-colors duration-300'
        type='submit'
        value='Send Message'
      />
    </form>
    
  </div>

  <div id='email-alert' class='hidden fixed right-4 top-4 sm:right-8 sm:top-8 z-50 flex max-w-sm w-full items-center justify-center rounded-2xl bg-gray-900 dark:bg-white p-4 shadow-2xl transition-all duration-300 transform -translate-y-full border border-gray-800 dark:border-gray-100'>
    <svg
      xmlns='http://www.w3.org/2000/svg'
      class='h-6 w-6 shrink-0 text-white dark:text-gray-900'
      fill='none'
      viewBox='0 0 24 24'
      stroke='currentColor'
    >
      <path
        stroke-linecap='round'
        stroke-linejoin='round'
        stroke-width='2'
        d='M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z'
      />
    </svg>
    <span class='ml-3 text-sm font-medium text-white dark:text-gray-900'>Your email has been sent!</span>
  </div>
</section>

<script>
  import emailjs from '@emailjs/browser';

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const alertBox = document.getElementById('email-alert');
  let alertTimer: number;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    emailjs.sendForm('gmail', 'template', form, 'x0R3Mx5UACm3xeqpG')
      .then(
        (result) => {
          console.log(result.text + ', Email sent!');
          
          alertBox?.classList.remove('hidden');
          setTimeout(() => {
            alertBox?.classList.remove('-translate-y-full');
            alertBox?.classList.add('translate-y-0');
          }, 10);
          
          clearTimeout(alertTimer);
          alertTimer = setTimeout(() => {
            alertBox?.classList.remove('translate-y-0');
            alertBox?.classList.add('-translate-y-full');
            setTimeout(() => alertBox?.classList.add('hidden'), 300);
          }, 5000) as unknown as number;
          
          form.reset();
        },
        (error) => {
          console.log(error.text);
        }
      );
  });
</script>