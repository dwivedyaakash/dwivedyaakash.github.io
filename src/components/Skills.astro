---
const skillCategories = [
  {
    title: 'Languages',
    skills: ['Kotlin', 'Java', 'JavaScript', 'TypeScript'],
  },
  {
    title: 'Android Development',
    skills: [
      'Android SDK',
      'XML',
      'Jetpack Compose',
      'MVVM & Clean Architecture',
      'Coroutines & Flow',
      'RoomDB & Dagger Hilt',
      'Retrofit & Ktor',
    ],
  },
  {
    title: 'Cross-Platform',
    skills: ['React Native', 'Expo', 'Zustand', 'Redux', 'Context API', 'Nativewind'],
  },
  {
    title: 'Tools & Technologies',
    skills: ['Git', 'Firebase', 'REST APIs', 'WebSockets', 'Postman'],
  },
];
---

<section id='skills' class='py-8 md:py-12 max-w-7xl mx-auto px-6 lg:px-8'>
  
  <h2 class='text-center text-3xl font-bold text-gray-900 dark:text-white mb-8 tracking-tight'>
    Skills
  </h2>

  <div class='bg-white dark:bg-[#111] rounded-2xl border border-gray-100 dark:border-neutral-800 shadow-xl shadow-gray-200/40 dark:shadow-none grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 p-6 sm:p-8 md:p-10 transition-all duration-300'>
    {
      skillCategories.map((category) => (
        <div class='flex flex-col'>
          
          <h3 class='text-lg sm:text-xl font-bold text-gray-900 dark:text-white mb-4'>
            {category.title}
          </h3>

          <div class='flex flex-wrap gap-2 sm:gap-3'>
            {category.skills.map((skill) => (
              <span class='px-4 py-2 bg-transparent text-gray-600 dark:text-gray-400 text-sm font-medium rounded-full border border-gray-200 dark:border-neutral-700 hover:border-gray-900 dark:hover:border-gray-200 hover:text-gray-900 dark:hover:text-white hover:-translate-y-0.5 transition-all duration-300 cursor-default'>
                {skill}
              </span>
            ))}
          </div>
          
        </div>
      ))
    }
  </div>
</section>