---
const skillCategories = [
  {
    title: 'Languages',
    skills: ['Kotlin', 'Java', 'JavaScript', 'TypeScript'],
  },
  {
    title: 'Android Development',
    skills: [
      'Android SDK',
      'XML',
      'Jetpack Compose',
      'MVVM & Clean Architecture',
      'Coroutines & Flow',
      'RoomDB & Dagger Hilt',
      'Retrofit & Ktor',
    ],
  },
  {
    title: 'Cross-Platform',
    skills: ['React Native', 'Expo', 'Zustand', 'Redux', 'Context API', 'Nativewind'],
  },
  {
    title: 'Tools & Technologies',
    skills: ['Git', 'Firebase', 'REST APIs', 'WebSockets', 'Postman'],
  },
];
---

<section id='skills' class='my-20'>
  {/* Section Header */}
  <div class='mb-8 text-center px-6'>
    <h1 class='text-3xl font-bold text-gray-700 dark:text-gray-200'>Skills</h1>
  </div>

  {/* Skills Grid container */}
  <div class='bg-white dark:bg-[#111] rounded-xl grid grid-cols-1 md:grid-cols-2 gap-8 m-6 min-[300px]:m-10 sm:m-16 p-6 md:p-8 lg:p-10 transition-colors duration-300'>
      {
        skillCategories.map((category, index) => (
          <div class='flex flex-col'>
            {/* Category Title */}
            <h3 class='text-xl font-semibold text-gray-700 dark:text-gray-200 mb-4 pb-2'>
              {category.title}
            </h3>

            {/* Chips Container */}
            <div class='flex flex-wrap gap-2 md:gap-3'>
              {category.skills.map((skill, skillIndex) => (
                <span class='px-4 py-2 text-gray-700 dark:text-gray-300 text-sm font-medium rounded-full border border-gray-300 dark:border-[#333] hover:border-gray-400 dark:hover:border-[#555] hover:-translate-y-0.5 transition-all duration-200 cursor-default'>
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
</section>
